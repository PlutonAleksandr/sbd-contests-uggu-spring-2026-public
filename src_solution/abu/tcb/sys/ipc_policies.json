{
  "version": "1.0",
  "description": "Политики IPC для доменов TCB и Other",
  "policies": [
    {
      "source": "abu.app",
      "target": "tcb.security_monitor",
      "commands": ["authorize", "health", "events_ring", "events_full"],
      "default": "deny"
    },
    {
      "source": "abu.app",
      "target": "other.other_worker",
      "commands": ["compute", "health"],
      "default": "deny"
    }
  ]
}